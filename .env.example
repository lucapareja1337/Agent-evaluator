# ---------------------------------------------------------------------------
# Groq (obrigatório) — https://console.groq.com/keys
# ---------------------------------------------------------------------------
GROQ_API_KEY=gsk_cole_sua_chave_aqui

# ---------------------------------------------------------------------------
# Agente especialista
# ---------------------------------------------------------------------------
AGENT_MODEL=llama-3.1-8b-instant
AGENT_TEMPERATURE=0.3
AGENT_MAX_RETRIES=2

# ---------------------------------------------------------------------------
# Juiz (LLM-as-a-Judge)
# ---------------------------------------------------------------------------
JUDGE_MODEL=llama-3.3-70b-versatile
JUDGE_TEMPERATURE=0.0
JUDGE_MAX_RETRIES=2

# ---------------------------------------------------------------------------
# MLflow (observabilidade)
# Para rodar localmente: mlflow server --host 127.0.0.1 --port 5000
# Ou, sem servidor: MLFLOW_TRACKING_URI=file:./mlruns
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=llm-eval-system

# ---------------------------------------------------------------------------
# Memória / histórico
# HISTORY_BACKEND=memory   → volátil, não sobrevive a restart (dev/testes)
# HISTORY_BACKEND=sqlite   → persistente via LangGraph + SqliteSaver (recomendado)
# ---------------------------------------------------------------------------
HISTORY_BACKEND=sqlite
HISTORY_SQLITE_PATH=./data/checkpoints.sqlite

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
